# =============================================================================
# KIDURI 2026 - Backend Environment Configuration
# =============================================================================

APP_NAME="KIDURI 2026"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tokyo
APP_URL=http://localhost:8000
APP_LOCALE=ja
APP_FALLBACK_LOCALE=en

# Frontend URL (Next.js)
FRONTEND_URL=http://localhost:3000

# =============================================================================
# Database (PostgreSQL 16 + pgvector)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=kiduri
DB_USERNAME=kiduri
DB_PASSWORD=kiduri_secret

# =============================================================================
# Redis
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# Cache / Session / Queue
# =============================================================================
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
QUEUE_CONNECTION=redis

# =============================================================================
# Laravel Sanctum (SPA Authentication)
# =============================================================================
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:3000

# =============================================================================
# CORS
# =============================================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Broadcasting (Laravel Reverb)
# =============================================================================
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=kiduri-local
REVERB_APP_KEY=kiduri-reverb-key
REVERB_APP_SECRET=kiduri-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# =============================================================================
# OpenAI API (GPT-5 / Embedding)
# =============================================================================
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_REQUEST_TIMEOUT=30

# =============================================================================
# File Storage (S3互換 - MinIO / AWS S3)
# =============================================================================
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=kiduri-uploads
AWS_ENDPOINT=http://minio:9000
AWS_USE_PATH_STYLE_ENDPOINT=true

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@kiduri.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Python Analytics Engine
# =============================================================================
ANALYTICS_API_URL=http://analytics:8001

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Telescope (Development Only)
# =============================================================================
TELESCOPE_ENABLED=true
